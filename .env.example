# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (anon) key — safe to expose in client-side code
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — SERVER ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection string

# Pooled connection via PgBouncer (port 6543) — used at runtime
# Append: ?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Direct connection (port 5432) — used by Prisma migrations only
DIRECT_URL=
